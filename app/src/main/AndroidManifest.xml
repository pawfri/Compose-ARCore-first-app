<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- Limits app visibility in the Google Play Store to ARCore supported devices -->
    <uses-feature android:name="android.hardware.camera.ar" />
    <!-- Tag related to CAMERA. Google Play assume hardware related permissions are required by default -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <!-- Restricted to Depth-supported devices -->
    <uses-feature android:name="com.google.ar.core.depth" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Arcorefirstapp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Arcorefirstapp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Indicates if ARCore is "required" or "optional"  -->
        <meta-data android:name="com.google.ar.core" android:value="required" />
    </application>

</manifest>